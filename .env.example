# Trello Configuration
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_user_token
TRELLO_WEBHOOK_SECRET=your_trello_webhook_signing_secret
TRELLO_BOARD_ID=your_trello_board_id

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_org_or_username
GITHUB_REPO=your_github_repo_name

# LLM Configuration
# Set LLM_PROVIDER to "gemini" or "anthropic"
LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_or_anthropic_api_key

# Database Connection (SQLite)
DATABASE_URL=./orchestrator.db

# Bot Control: Comma-separated list of Trello member IDs or usernames to ignore
BOT_TRELLO_MEMBER_IDS=bot_member_id1,bot_member_id2

# Feature Flags (Safe Mode default: all false)
AUTO_REPLY_ENABLED=false
AUTO_CREATE_GITHUB_ISSUE=false
AUTO_CREATE_PLAN=false

# Server Configuration
PORT=8080
GIN_MODE=debug

# Deploy Configuration (for scripts/release.sh)
# DEPLOY_HOST=your.server.com
# DEPLOY_USER=deploy
# DEPLOY_PATH=/opt/trello-orchestrator
# DEPLOY_SERVICE=trello-orchestrator
# DEPLOY_BACKUPS=3
